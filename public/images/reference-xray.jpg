<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 600" width="800" height="600">
  <rect width="800" height="600" fill="#1a1a2e"/>
  <text x="400" y="280" text-anchor="middle" fill="#e2e8f0" font-size="24" font-family="Arial">Reference X-ray Placeholder</text>
  <text x="400" y="320" text-anchor="middle" fill="#94a3b8" font-size="16" font-family="Arial">Replace with actual equine hoof X-ray image</text>
  <text x="400" y="350" text-anchor="middle" fill="#64748b" font-size="14" font-family="Arial">Recommended: Lateral view, 512x512px or larger</text>
  <!-- Simple hoof outline -->
  <path d="M 350 200 Q 320 250 330 300 Q 340 350 360 380 Q 380 400 420 400 Q 460 400 480 380 Q 500 350 490 300 Q 480 250 450 200 Z" fill="none" stroke="#334155" stroke-width="2"/>
  <path d="M 360 220 Q 340 260 350 300 Q 360 340 380 360 Q 400 380 420 380 Q 440 380 460 360 Q 480 340 470 300 Q 460 260 440 220" fill="none" stroke="#475569" stroke-width="1"/>
  <!-- P3 bone outline -->
  <path d="M 370 240 Q 360 280 370 320 Q 380 360 400 370 Q 420 360 430 320 Q 440 280 430 240 Z" fill="none" stroke="#64748b" stroke-width="1"/>
</svg>
